    "Note that for Volumio players, the playqueue in Rigelian is not synchronized with the playqueue shown through the Volumio web interface.": {
      "localizations": {
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Let op: bij Volumio-spelers is de afspeelwachtrij in Rigelian niet gesynchroniseerd met de afspeelwachtrij die wordt weergegeven via de Volumio-webinterface."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Beachten Sie, dass bei Volumio-Playern die Wiedergabewarteschlange in Rigelian nicht mit der über die Volumio-Weboberfläche angezeigten Warteschlange synchronisiert ist."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Notez que pour les lecteurs Volumio, la file d’attente de lecture dans Rigelian n’est pas synchronisée avec celle affichée via l’interface Web de Volumio."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "Volumio プレーヤーでは、Rigelian の再生キューは Volumio のWebインターフェイスに表示される再生キューと同期されません。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "请注意，对于 Volumio 播放器，Rigelian 中的播放队列与 Volumio 网页界面显示的播放队列不同步。"
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Bemærk, at for Volumio-afspillere er afspilningskøen i Rigelian ikke synkroniseret med køen, der vises via Volumios webgrænseflade."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Observera att för Volumio-spelare är kölistan i Rigelian inte synkroniserad med kölistan som visas via Volumios webbgränssnitt."
          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "Merk at for Volumio-spillere er spillekøen i Rigelian ikke synkronisert med køen som vises via Volumios webgrensesnitt."
          }
        },
        "fi": {
          "stringUnit": {
            "state": "translated",
            "value": "Huomaa, että Volumio-soittimissa Rigelianin toistojono ei ole synkronoitu Volumion verkkokäyttöliittymässä näkyvän jonon kanssa."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Зверніть увагу, що для плеєрів Volumio черга відтворення в Rigelian не синхронізується з чергою, показаною у веб-інтерфейсі Volumio."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Ten en cuenta que en los reproductores Volumio, la cola de reproducción en Rigelian no está sincronizada con la cola mostrada en la interfaz web de Volumio."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Observe que, nos reprodutores Volumio, a fila de reprodução no Rigelian não é sincronizada com a fila exibida pela interface web do Volumio."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Nota che per i lettori Volumio, la coda di riproduzione in Rigelian non è sincronizzata con la coda mostrata tramite l’interfaccia web di Volumio."
          }
        }
      }
    },
