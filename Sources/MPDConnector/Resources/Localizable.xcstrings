          "stringUnit": {
            "state": "translated",
            "value": "Er du sikker på at du vil slette denne spilleren?"
          }
        },
        "fi": {
          "stringUnit": {
            "state": "translated",
            "value": "Haluatko varmasti poistaa tämän soittimen?"
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Ви впевнені, що хочете видалити цей плеєр?"
