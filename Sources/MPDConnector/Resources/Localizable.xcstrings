    "Are you sure you want to delete this player?": {
      "localizations": {
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Weet je zeker dat je deze speler wil verwijderen?"
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Möchten Sie diesen Player wirklich löschen?"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Voulez-vous vraiment supprimer ce lecteur ?"
          }
        },
        "ja": {
