    "Note that for Volumio players, the playqueue in Rigelian is not synchronized with the playqueue shown through the Volumio web interface." : {
      "localizations" : {
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Let op: bij Volumio-spelers is de afspeelwachtrij in Rigelian niet gesynchroniseerd met de afspeelwachtrij die wordt weergegeven via de Volumio-webinterface."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Beachten Sie, dass bei Volumio-Playern die Wiedergabewarteschlange in Rigelian nicht mit der über die Volumio-Weboberfläche angezeigten Warteschlange synchronisiert ist."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Notez que pour les lecteurs Volumio, la file d’attente de lecture dans Rigelian n’est pas synchronisée avec celle affichée via l’interface Web de Volumio."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Volumio プレーヤーでは、Rigelian の再生キューは Volumio のWebインターフェイスに表示される再生キューと同期されません。"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "请注意，对于 Volumio 播放器，Rigelian 中的播放队列与 Volumio 网页界面显示的播放队列不同步。"
          }
        }
      }
    },
